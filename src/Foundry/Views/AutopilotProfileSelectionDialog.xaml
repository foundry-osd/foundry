<Window
    x:Class="Foundry.Views.AutopilotProfileSelectionDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="{Binding Strings[Autopilot.TenantPickerTitle]}"
    Width="880"
    Height="620"
    MinWidth="720"
    MinHeight="520"
    ResizeMode="CanResize"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterOwner">
    <Window.InputBindings>
        <KeyBinding
            Key="A"
            Command="{Binding SelectAllCommand}"
            Modifiers="Control" />
    </Window.InputBindings>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock
            FontSize="24"
            FontWeight="SemiBold"
            Foreground="{DynamicResource TextFillColorPrimaryBrush}"
            Text="{Binding Strings[Autopilot.TenantPickerTitle]}" />

        <Grid Grid.Row="1" Margin="0,16,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock
                    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                    Text="{Binding Strings[Autopilot.TenantPickerDescription]}"
                    TextWrapping="Wrap" />
                <TextBlock
                    Margin="0,6,0,0"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Text="{Binding SelectedCountDisplay}" />
            </StackPanel>

            <Button
                Grid.Column="1"
                MinWidth="110"
                Margin="12,0,8,0"
                Command="{Binding SelectAllCommand}"
                Content="{Binding Strings[Autopilot.TenantPickerSelectAll]}" />

            <Button
                Grid.Column="2"
                MinWidth="110"
                Command="{Binding ClearSelectionCommand}"
                Content="{Binding Strings[Autopilot.TenantPickerClear]}" />
        </Grid>

        <Border
            Grid.Row="2"
            Padding="12"
            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <ListView
                x:Name="ProfilesListView"
                ItemsSource="{Binding Profiles}"
                ScrollViewer.CanContentScroll="True">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Width="72">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox HorizontalAlignment="Center" IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Width="240" DisplayMemberBinding="{Binding DisplayName}">
                            <GridViewColumn.Header>
                                <TextBlock Text="{Binding DataContext.Strings[Autopilot.ColumnName], ElementName=ProfilesListView}" />
                            </GridViewColumn.Header>
                        </GridViewColumn>
                        <GridViewColumn Width="460" DisplayMemberBinding="{Binding FolderName}">
                            <GridViewColumn.Header>
                                <TextBlock Text="{Binding DataContext.Strings[Autopilot.ColumnFolder], ElementName=ProfilesListView}" />
                            </GridViewColumn.Header>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>

        <StackPanel
            Grid.Row="3"
            Margin="0,16,0,0"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                Width="120"
                Margin="0,0,8,0"
                Command="{Binding CancelCommand}"
                Content="{Binding Strings[Autopilot.TenantPickerCancel]}"
                IsCancel="True" />
            <Button
                Width="120"
                Command="{Binding ImportSelectedProfilesCommand}"
                Content="{Binding Strings[Autopilot.TenantPickerImport]}"
                IsDefault="True"
                Style="{DynamicResource AccentButtonStyle}" />
        </StackPanel>
    </Grid>
</Window>
