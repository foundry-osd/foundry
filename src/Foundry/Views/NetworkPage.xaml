<?xml version="1.0" encoding="utf-8" ?>
<Page x:Class="Foundry.Views.NetworkPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:wct="using:CommunityToolkit.WinUI.Controls"
      mc:Ignorable="d">
    <ScrollView Margin="{ThemeResource ContentPageMargin}"
                Padding="{ThemeResource ContentPagePadding}"
                VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="{ThemeResource FoundryPageContentInset}"
                    Spacing="{ThemeResource FoundrySettingsSectionSpacing}">
            <TextBlock Text="{x:Bind ViewModel.PageTitle, Mode=OneWay}"
                       Style="{ThemeResource FoundryPageTitleTextBlockStyle}" />

            <wct:SettingsExpander Header="{x:Bind ViewModel.EthernetHeader, Mode=OneWay}"
                                  Description="{x:Bind ViewModel.EthernetDescription, Mode=OneWay}"
                                  IsExpanded="{x:Bind ViewModel.IsDot1xExpanded, Mode=TwoWay}">
                <wct:SettingsExpander.HeaderIcon>
                    <FontIcon Glyph="&#xE839;" />
                </wct:SettingsExpander.HeaderIcon>
                <ToggleSwitch AutomationProperties.Name="{x:Bind ViewModel.Dot1xEnableText, Mode=OneWay}"
                              IsOn="{x:Bind ViewModel.IsDot1xEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <wct:SettingsExpander.Items>
                    <wct:SettingsCard Header="{x:Bind ViewModel.ProfileTemplateLabel, Mode=OneWay}"
                                      HorizontalContentAlignment="Stretch"
                                      Visibility="{x:Bind ViewModel.Dot1xSettingsVisibility, Mode=OneWay}">
                        <StackPanel Spacing="{ThemeResource FoundrySpace4}">
                            <Grid ColumnSpacing="{ThemeResource FoundryInlineControlSpacing}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{x:Bind ViewModel.Dot1xProfileTemplatePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Grid.Column="1"
                                        MinWidth="{StaticResource SettingActionControlMinWidth}"
                                        Command="{x:Bind ViewModel.BrowseDot1xProfileTemplateCommand}"
                                        Content="{x:Bind ViewModel.BrowseButtonText, Mode=OneWay}" />
                            </Grid>
                            <TextBlock Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                       Text="{x:Bind ViewModel.Dot1xProfileTemplateValidationMessage, Mode=OneWay}"
                                       TextWrapping="WrapWholeWords"
                                       Visibility="{x:Bind ViewModel.Dot1xProfileTemplateValidationVisibility, Mode=OneWay}" />
                        </StackPanel>
                    </wct:SettingsCard>
                    <wct:SettingsCard Header="{x:Bind ViewModel.RequiresCertificateText, Mode=OneWay}"
                                      Visibility="{x:Bind ViewModel.Dot1xSettingsVisibility, Mode=OneWay}">
                        <ToggleSwitch IsOn="{x:Bind ViewModel.IsDot1xCertificateRequired, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </wct:SettingsCard>
                    <wct:SettingsCard Header="{x:Bind ViewModel.Dot1xCertificateLabel, Mode=OneWay}"
                                      HorizontalContentAlignment="Stretch"
                                      Visibility="{x:Bind ViewModel.Dot1xCertificatePathVisibility, Mode=OneWay}">
                        <StackPanel Spacing="{ThemeResource FoundrySpace4}">
                            <Grid ColumnSpacing="{ThemeResource FoundryInlineControlSpacing}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{x:Bind ViewModel.Dot1xCertificatePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Grid.Column="1"
                                        MinWidth="{StaticResource SettingActionControlMinWidth}"
                                        Command="{x:Bind ViewModel.BrowseDot1xCertificateCommand}"
                                        Content="{x:Bind ViewModel.BrowseButtonText, Mode=OneWay}" />
                            </Grid>
                            <TextBlock Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                       Text="{x:Bind ViewModel.Dot1xCertificateValidationMessage, Mode=OneWay}"
                                       TextWrapping="WrapWholeWords"
                                       Visibility="{x:Bind ViewModel.Dot1xCertificateValidationVisibility, Mode=OneWay}" />
                        </StackPanel>
                    </wct:SettingsCard>
                </wct:SettingsExpander.Items>
            </wct:SettingsExpander>

            <wct:SettingsExpander Header="{x:Bind ViewModel.WifiHeader, Mode=OneWay}"
                                  Description="{x:Bind ViewModel.WifiDescription, Mode=OneWay}"
                                  IsExpanded="{x:Bind ViewModel.IsWifiExpanded, Mode=TwoWay}">
                <wct:SettingsExpander.HeaderIcon>
                    <FontIcon Glyph="&#xE701;" />
                </wct:SettingsExpander.HeaderIcon>
                <ToggleSwitch AutomationProperties.Name="{x:Bind ViewModel.WifiProvisionedText, Mode=OneWay}"
                              IsOn="{x:Bind ViewModel.IsWifiProvisioned, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <wct:SettingsExpander.Items>
                    <wct:SettingsCard Header="{x:Bind ViewModel.WifiConfiguredText, Mode=OneWay}"
                                      Visibility="{x:Bind ViewModel.WifiConfiguredVisibility, Mode=OneWay}">
                        <ToggleSwitch IsOn="{x:Bind ViewModel.IsWifiConfigured, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </wct:SettingsCard>
                    <wct:SettingsCard Header="{x:Bind ViewModel.WifiSsidLabel, Mode=OneWay}"
                                      HorizontalContentAlignment="Stretch"
                                      Visibility="{x:Bind ViewModel.WifiConfigurationFieldsVisibility, Mode=OneWay}">
                        <StackPanel Spacing="{ThemeResource FoundrySpace4}">
                            <TextBox Text="{x:Bind ViewModel.WifiSsid, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                       Text="{x:Bind ViewModel.WifiSsidValidationMessage, Mode=OneWay}"
                                       TextWrapping="WrapWholeWords"
                                       Visibility="{x:Bind ViewModel.WifiSsidValidationVisibility, Mode=OneWay}" />
                        </StackPanel>
                    </wct:SettingsCard>
                    <wct:SettingsCard Header="{x:Bind ViewModel.WifiSecurityTypeLabel, Mode=OneWay}"
                                      HorizontalContentAlignment="Stretch"
                                      Visibility="{x:Bind ViewModel.WifiConfigurationFieldsVisibility, Mode=OneWay}">
                        <StackPanel Spacing="{ThemeResource FoundrySpace4}">
                            <ComboBox DisplayMemberPath="DisplayName"
                                      HorizontalAlignment="Stretch"
                                      ItemsSource="{x:Bind ViewModel.WifiSecurityTypes, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.SelectedWifiSecurityType, Mode=TwoWay}" />
                            <TextBlock Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                       Text="{x:Bind ViewModel.WifiSecurityTypeValidationMessage, Mode=OneWay}"
                                       TextWrapping="WrapWholeWords"
                                       Visibility="{x:Bind ViewModel.WifiSecurityTypeValidationVisibility, Mode=OneWay}" />
                        </StackPanel>
                    </wct:SettingsCard>
                    <wct:SettingsCard Header="{x:Bind ViewModel.WifiPassphraseLabel, Mode=OneWay}"
                                      Description="{x:Bind ViewModel.WifiPersonalDescription, Mode=OneWay}"
                                      HorizontalContentAlignment="Stretch"
                                      Visibility="{x:Bind ViewModel.WifiPersonalSettingsVisibility, Mode=OneWay}">
                        <StackPanel Spacing="{ThemeResource FoundrySpace4}">
                            <PasswordBox x:Name="WifiPassphraseBox"
                                         Loaded="WifiPassphraseBox_OnLoaded"
                                         PasswordChanged="WifiPassphraseBox_OnPasswordChanged" />
                            <TextBlock Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                       Text="{x:Bind ViewModel.WifiPassphraseValidationMessage, Mode=OneWay}"
                                       TextWrapping="WrapWholeWords"
                                       Visibility="{x:Bind ViewModel.WifiPassphraseValidationVisibility, Mode=OneWay}" />
                        </StackPanel>
                    </wct:SettingsCard>
                    <wct:SettingsCard Header="{x:Bind ViewModel.WifiEnterpriseHeader, Mode=OneWay}"
                                      Description="{x:Bind ViewModel.WifiEnterpriseDescription, Mode=OneWay}"
                                      HorizontalContentAlignment="Stretch"
                                      Visibility="{x:Bind ViewModel.WifiEnterpriseSettingsVisibility, Mode=OneWay}">
                        <StackPanel Spacing="{ThemeResource FoundrySpace4}">
                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Text="{x:Bind ViewModel.WifiEnterpriseTemplateText, Mode=OneWay}"
                                       TextWrapping="WrapWholeWords" />
                            <Grid ColumnSpacing="{ThemeResource FoundryInlineControlSpacing}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{x:Bind ViewModel.WifiEnterpriseProfileTemplatePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Grid.Column="1"
                                        MinWidth="{StaticResource SettingActionControlMinWidth}"
                                        Command="{x:Bind ViewModel.BrowseWifiEnterpriseProfileTemplateCommand}"
                                        Content="{x:Bind ViewModel.BrowseButtonText, Mode=OneWay}" />
                            </Grid>
                            <TextBlock Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                       Text="{x:Bind ViewModel.WifiEnterpriseTemplateValidationMessage, Mode=OneWay}"
                                       TextWrapping="WrapWholeWords"
                                       Visibility="{x:Bind ViewModel.WifiEnterpriseTemplateValidationVisibility, Mode=OneWay}" />
                        </StackPanel>
                    </wct:SettingsCard>
                    <wct:SettingsCard Header="{x:Bind ViewModel.RequiresCertificateText, Mode=OneWay}"
                                      Visibility="{x:Bind ViewModel.WifiEnterpriseSettingsVisibility, Mode=OneWay}">
                        <ToggleSwitch IsOn="{x:Bind ViewModel.IsWifiCertificateRequired, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </wct:SettingsCard>
                    <wct:SettingsCard Header="{x:Bind ViewModel.WifiCertificateLabel, Mode=OneWay}"
                                      HorizontalContentAlignment="Stretch"
                                      Visibility="{x:Bind ViewModel.WifiCertificatePathVisibility, Mode=OneWay}">
                        <StackPanel Spacing="{ThemeResource FoundrySpace4}">
                            <Grid ColumnSpacing="{ThemeResource FoundryInlineControlSpacing}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{x:Bind ViewModel.WifiCertificatePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <Button Grid.Column="1"
                                        MinWidth="{StaticResource SettingActionControlMinWidth}"
                                        Command="{x:Bind ViewModel.BrowseWifiCertificateCommand}"
                                        Content="{x:Bind ViewModel.BrowseButtonText, Mode=OneWay}" />
                            </Grid>
                            <TextBlock Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                       Text="{x:Bind ViewModel.WifiCertificateValidationMessage, Mode=OneWay}"
                                       TextWrapping="WrapWholeWords"
                                       Visibility="{x:Bind ViewModel.WifiCertificateValidationVisibility, Mode=OneWay}" />
                        </StackPanel>
                    </wct:SettingsCard>
                </wct:SettingsExpander.Items>
            </wct:SettingsExpander>
        </StackPanel>
    </ScrollView>
</Page>
