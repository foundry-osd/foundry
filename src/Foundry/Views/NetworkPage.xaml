<?xml version="1.0" encoding="utf-8" ?>
<Page x:Class="Foundry.Views.NetworkPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="using:Foundry.Behaviors"
    xmlns:controls="using:Foundry.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:wct="using:CommunityToolkit.WinUI.Controls"
    mc:Ignorable="d">
    <ScrollView
        Margin="{ThemeResource ContentPageMargin}"
        Padding="{ThemeResource ContentPagePadding}"
        VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="{ThemeResource FoundrySettingsSectionSpacing}">
            <controls:PageHeader
                Title="{x:Bind ViewModel.PageTitle, Mode=OneWay}"
                Description="{x:Bind ViewModel.PageDescription, Mode=OneWay}"
                IconGlyph="&#xE774;"
                DocumentationUrl="{x:Bind ViewModel.DocumentationUrl, Mode=OneWay}" />

            <wct:SettingsExpander
                Description="{x:Bind ViewModel.EthernetDescription, Mode=OneWay}"
                Header="{x:Bind ViewModel.EthernetHeader, Mode=OneWay}"
                IsExpanded="{x:Bind ViewModel.IsDot1xExpanded, Mode=TwoWay}">
                <wct:SettingsExpander.HeaderIcon>
                    <FontIcon Glyph="&#xE839;" />
                </wct:SettingsExpander.HeaderIcon>
                <ToggleSwitch
                    behaviors:LocalizedToggleSwitch.UseLocalizedStateContent="True"
                    AutomationProperties.Name="{x:Bind ViewModel.Dot1xEnableText, Mode=OneWay}"
                    IsOn="{x:Bind ViewModel.IsDot1xEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <wct:SettingsExpander.Items>
                    <wct:SettingsCard
                        HorizontalContentAlignment="Stretch"
                        Header="{x:Bind ViewModel.ProfileTemplateLabel, Mode=OneWay}"
                        Visibility="{x:Bind ViewModel.Dot1xSettingsVisibility, Mode=OneWay}">
                        <StackPanel
                            HorizontalAlignment="Right"
                            Spacing="{ThemeResource FoundrySpace4}">
                            <Grid ColumnSpacing="{ThemeResource FoundryInlineControlSpacing}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox
                                    Width="{ThemeResource FoundryWideInputMinWidth}"
                                    Text="{x:Bind ViewModel.Dot1xProfileTemplatePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <Button
                                    Grid.Column="1"
                                    MinWidth="{StaticResource SettingActionControlMinWidth}"
                                    Command="{x:Bind ViewModel.BrowseDot1xProfileTemplateCommand}"
                                    Content="{x:Bind ViewModel.BrowseButtonText, Mode=OneWay}" />
                            </Grid>
                            <TextBlock
                                Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                Text="{x:Bind ViewModel.Dot1xProfileTemplateValidationMessage, Mode=OneWay}"
                                TextWrapping="WrapWholeWords"
                                Visibility="{x:Bind ViewModel.Dot1xProfileTemplateValidationVisibility, Mode=OneWay}" />
                        </StackPanel>
                    </wct:SettingsCard>
                    <wct:SettingsCard
                        Header="{x:Bind ViewModel.RequiresCertificateText, Mode=OneWay}"
                        Visibility="{x:Bind ViewModel.Dot1xSettingsVisibility, Mode=OneWay}">
                        <ToggleSwitch
                            behaviors:LocalizedToggleSwitch.UseLocalizedStateContent="True"
                            IsOn="{x:Bind ViewModel.IsDot1xCertificateRequired, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </wct:SettingsCard>
                    <wct:SettingsCard
                        HorizontalContentAlignment="Stretch"
                        Header="{x:Bind ViewModel.Dot1xCertificateLabel, Mode=OneWay}"
                        Visibility="{x:Bind ViewModel.Dot1xCertificatePathVisibility, Mode=OneWay}">
                        <StackPanel
                            HorizontalAlignment="Right"
                            Spacing="{ThemeResource FoundrySpace4}">
                            <Grid ColumnSpacing="{ThemeResource FoundryInlineControlSpacing}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox
                                    Width="{ThemeResource FoundryWideInputMinWidth}"
                                    Text="{x:Bind ViewModel.Dot1xCertificatePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <Button
                                    Grid.Column="1"
                                    MinWidth="{StaticResource SettingActionControlMinWidth}"
                                    Command="{x:Bind ViewModel.BrowseDot1xCertificateCommand}"
                                    Content="{x:Bind ViewModel.BrowseButtonText, Mode=OneWay}" />
                            </Grid>
                            <TextBlock
                                Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                Text="{x:Bind ViewModel.Dot1xCertificateValidationMessage, Mode=OneWay}"
                                TextWrapping="WrapWholeWords"
                                Visibility="{x:Bind ViewModel.Dot1xCertificateValidationVisibility, Mode=OneWay}" />
                        </StackPanel>
                    </wct:SettingsCard>
                </wct:SettingsExpander.Items>
            </wct:SettingsExpander>

            <wct:SettingsExpander
                Description="{x:Bind ViewModel.WifiDescription, Mode=OneWay}"
                Header="{x:Bind ViewModel.WifiHeader, Mode=OneWay}"
                IsExpanded="{x:Bind ViewModel.IsWifiExpanded, Mode=TwoWay}">
                <wct:SettingsExpander.HeaderIcon>
                    <FontIcon Glyph="&#xE701;" />
                </wct:SettingsExpander.HeaderIcon>
                <ToggleSwitch
                    behaviors:LocalizedToggleSwitch.UseLocalizedStateContent="True"
                    AutomationProperties.Name="{x:Bind ViewModel.WifiProvisionedText, Mode=OneWay}"
                    IsOn="{x:Bind ViewModel.IsWifiProvisioned, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <wct:SettingsExpander.Items>
                    <wct:SettingsCard
                        Header="{x:Bind ViewModel.WifiConfiguredText, Mode=OneWay}"
                        Visibility="{x:Bind ViewModel.WifiConfiguredVisibility, Mode=OneWay}">
                        <ToggleSwitch
                            behaviors:LocalizedToggleSwitch.UseLocalizedStateContent="True"
                            IsOn="{x:Bind ViewModel.IsWifiConfigured, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </wct:SettingsCard>
                    <wct:SettingsCard
                        HorizontalContentAlignment="Stretch"
                        Header="{x:Bind ViewModel.WifiSsidLabel, Mode=OneWay}"
                        Visibility="{x:Bind ViewModel.WifiConfigurationFieldsVisibility, Mode=OneWay}">
                        <StackPanel
                            HorizontalAlignment="Right"
                            Spacing="{ThemeResource FoundrySpace4}">
                            <TextBox
                                Width="{ThemeResource FoundryWideInputMinWidth}"
                                Text="{x:Bind ViewModel.WifiSsid, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock
                                Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                Text="{x:Bind ViewModel.WifiSsidValidationMessage, Mode=OneWay}"
                                TextWrapping="WrapWholeWords"
                                Visibility="{x:Bind ViewModel.WifiSsidValidationVisibility, Mode=OneWay}" />
                        </StackPanel>
                    </wct:SettingsCard>
                    <wct:SettingsCard
                        HorizontalContentAlignment="Stretch"
                        Header="{x:Bind ViewModel.WifiSecurityTypeLabel, Mode=OneWay}"
                        Visibility="{x:Bind ViewModel.WifiConfigurationFieldsVisibility, Mode=OneWay}">
                        <StackPanel
                            HorizontalAlignment="Right"
                            Spacing="{ThemeResource FoundrySpace4}">
                            <ComboBox
                                Width="{ThemeResource FoundryWideInputMinWidth}"
                                DisplayMemberPath="DisplayName"
                                ItemsSource="{x:Bind ViewModel.WifiSecurityTypes, Mode=OneWay}"
                                SelectedItem="{x:Bind ViewModel.SelectedWifiSecurityType, Mode=TwoWay}" />
                            <TextBlock
                                Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                Text="{x:Bind ViewModel.WifiSecurityTypeValidationMessage, Mode=OneWay}"
                                TextWrapping="WrapWholeWords"
                                Visibility="{x:Bind ViewModel.WifiSecurityTypeValidationVisibility, Mode=OneWay}" />
                        </StackPanel>
                    </wct:SettingsCard>
                    <wct:SettingsCard
                        HorizontalContentAlignment="Stretch"
                        Description="{x:Bind ViewModel.WifiPersonalDescription, Mode=OneWay}"
                        Header="{x:Bind ViewModel.WifiPassphraseLabel, Mode=OneWay}"
                        Visibility="{x:Bind ViewModel.WifiPersonalSettingsVisibility, Mode=OneWay}">
                        <StackPanel
                            HorizontalAlignment="Right"
                            Spacing="{ThemeResource FoundrySpace4}">
                            <PasswordBox x:Name="WifiPassphraseBox"
                                Width="{ThemeResource FoundryWideInputMinWidth}"
                                Loaded="WifiPassphraseBox_OnLoaded"
                                PasswordChanged="WifiPassphraseBox_OnPasswordChanged" />
                            <TextBlock
                                Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                Text="{x:Bind ViewModel.WifiPassphraseValidationMessage, Mode=OneWay}"
                                TextWrapping="WrapWholeWords"
                                Visibility="{x:Bind ViewModel.WifiPassphraseValidationVisibility, Mode=OneWay}" />
                        </StackPanel>
                    </wct:SettingsCard>
                    <wct:SettingsCard
                        HorizontalContentAlignment="Stretch"
                        Description="{x:Bind ViewModel.WifiEnterpriseDescription, Mode=OneWay}"
                        Header="{x:Bind ViewModel.WifiEnterpriseHeader, Mode=OneWay}"
                        Visibility="{x:Bind ViewModel.WifiEnterpriseSettingsVisibility, Mode=OneWay}">
                        <StackPanel
                            HorizontalAlignment="Right"
                            Spacing="{ThemeResource FoundrySpace4}">
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="{x:Bind ViewModel.WifiEnterpriseTemplateText, Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />
                            <Grid ColumnSpacing="{ThemeResource FoundryInlineControlSpacing}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox
                                    Width="{ThemeResource FoundryWideInputMinWidth}"
                                    Text="{x:Bind ViewModel.WifiEnterpriseProfileTemplatePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <Button
                                    Grid.Column="1"
                                    MinWidth="{StaticResource SettingActionControlMinWidth}"
                                    Command="{x:Bind ViewModel.BrowseWifiEnterpriseProfileTemplateCommand}"
                                    Content="{x:Bind ViewModel.BrowseButtonText, Mode=OneWay}" />
                            </Grid>
                            <TextBlock
                                Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                Text="{x:Bind ViewModel.WifiEnterpriseTemplateValidationMessage, Mode=OneWay}"
                                TextWrapping="WrapWholeWords"
                                Visibility="{x:Bind ViewModel.WifiEnterpriseTemplateValidationVisibility, Mode=OneWay}" />
                        </StackPanel>
                    </wct:SettingsCard>
                    <wct:SettingsCard
                        Header="{x:Bind ViewModel.RequiresCertificateText, Mode=OneWay}"
                        Visibility="{x:Bind ViewModel.WifiEnterpriseSettingsVisibility, Mode=OneWay}">
                        <ToggleSwitch
                            behaviors:LocalizedToggleSwitch.UseLocalizedStateContent="True"
                            IsOn="{x:Bind ViewModel.IsWifiCertificateRequired, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </wct:SettingsCard>
                    <wct:SettingsCard
                        HorizontalContentAlignment="Stretch"
                        Header="{x:Bind ViewModel.WifiCertificateLabel, Mode=OneWay}"
                        Visibility="{x:Bind ViewModel.WifiCertificatePathVisibility, Mode=OneWay}">
                        <StackPanel
                            HorizontalAlignment="Right"
                            Spacing="{ThemeResource FoundrySpace4}">
                            <Grid ColumnSpacing="{ThemeResource FoundryInlineControlSpacing}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox
                                    Width="{ThemeResource FoundryWideInputMinWidth}"
                                    Text="{x:Bind ViewModel.WifiCertificatePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <Button
                                    Grid.Column="1"
                                    MinWidth="{StaticResource SettingActionControlMinWidth}"
                                    Command="{x:Bind ViewModel.BrowseWifiCertificateCommand}"
                                    Content="{x:Bind ViewModel.BrowseButtonText, Mode=OneWay}" />
                            </Grid>
                            <TextBlock
                                Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                Text="{x:Bind ViewModel.WifiCertificateValidationMessage, Mode=OneWay}"
                                TextWrapping="WrapWholeWords"
                                Visibility="{x:Bind ViewModel.WifiCertificateValidationVisibility, Mode=OneWay}" />
                        </StackPanel>
                    </wct:SettingsCard>
                </wct:SettingsExpander.Items>
            </wct:SettingsExpander>

            <wct:SettingsExpander
                Description="{x:Bind ViewModel.WindowsRoamingDescription, Mode=OneWay}"
                Header="{x:Bind ViewModel.WindowsRoamingHeader, Mode=OneWay}"
                IsEnabled="{x:Bind ViewModel.IsNetworkProfileRoamingAvailable, Mode=OneWay}"
                IsExpanded="{x:Bind ViewModel.IsWindowsRoamingExpanded, Mode=TwoWay}">
                <wct:SettingsExpander.HeaderIcon>
                    <FontIcon Glyph="&#xE8AB;" />
                </wct:SettingsExpander.HeaderIcon>
                <ToggleSwitch
                    behaviors:LocalizedToggleSwitch.UseLocalizedStateContent="True"
                    AutomationProperties.Name="{x:Bind ViewModel.RoamNetworkProfilesText, Mode=OneWay}"
                    IsEnabled="{x:Bind ViewModel.IsNetworkProfileRoamingAvailable, Mode=OneWay}"
                    IsOn="{x:Bind ViewModel.IsNetworkProfileRoamingEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <wct:SettingsExpander.Items>
                    <wct:SettingsCard
                        Description="{x:Bind ViewModel.RoamPrivateKeyMaterialDescription, Mode=OneWay}"
                        Header="{x:Bind ViewModel.RoamPrivateKeyMaterialText, Mode=OneWay}"
                        Visibility="{x:Bind ViewModel.RoamPrivateKeyMaterialVisibility, Mode=OneWay}">
                        <ToggleSwitch
                            behaviors:LocalizedToggleSwitch.UseLocalizedStateContent="True"
                            IsEnabled="{x:Bind ViewModel.IsPrivateKeyMaterialRoamingEnabled, Mode=OneWay}"
                            IsOn="{x:Bind ViewModel.IsPrivateKeyMaterialRoamingRequested, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </wct:SettingsCard>
                </wct:SettingsExpander.Items>
            </wct:SettingsExpander>
        </StackPanel>
    </ScrollView>
</Page>
