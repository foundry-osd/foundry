<Page
    x:Class="Foundry.Views.NetworkPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel Padding="32" Spacing="16" MaxWidth="980">
            <TextBlock Text="Network" Style="{ThemeResource TitleTextBlockStyle}" />
            <InfoBar Title="Validation" Message="{Binding ValidationMessage}" IsOpen="{Binding HasValidationError}" Severity="Error" />
            <CheckBox Content="Enable 802.1X" IsChecked="{Binding IsDot1xEnabled, Mode=TwoWay}" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <TextBox Header="802.1X profile template" Text="{Binding Dot1xProfileTemplatePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <Button Grid.Column="1" Content="Browse" Command="{Binding BrowseDot1xProfileTemplateCommand}" VerticalAlignment="Bottom" />
            </Grid>
            <CheckBox Content="802.1X certificate required" IsChecked="{Binding IsDot1xCertificateRequired, Mode=TwoWay}" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <TextBox Header="802.1X certificate" Text="{Binding Dot1xCertificatePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <Button Grid.Column="1" Content="Browse" Command="{Binding BrowseDot1xCertificateCommand}" VerticalAlignment="Bottom" />
            </Grid>
            <CheckBox Content="Provision Wi-Fi" IsChecked="{Binding IsWifiProvisioned, Mode=TwoWay}" />
            <CheckBox Content="Configure Wi-Fi" IsChecked="{Binding IsWifiConfigured, Mode=TwoWay}" />
            <TextBox Header="SSID" Text="{Binding WifiSsid, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <ComboBox Header="Security" ItemsSource="{Binding WifiSecurityTypes}" SelectedValue="{Binding WifiSecurityType, Mode=TwoWay}" SelectedValuePath="Value" DisplayMemberPath="DisplayName" />
            <PasswordBox Header="Passphrase" PasswordChanged="OnWifiPasswordChanged" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <TextBox Header="Wi-Fi enterprise profile" Text="{Binding WifiEnterpriseProfileTemplatePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <Button Grid.Column="1" Content="Browse" Command="{Binding BrowseWifiEnterpriseProfileTemplateCommand}" VerticalAlignment="Bottom" />
            </Grid>
            <CheckBox Content="Wi-Fi certificate required" IsChecked="{Binding IsWifiCertificateRequired, Mode=TwoWay}" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <TextBox Header="Wi-Fi certificate" Text="{Binding WifiCertificatePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <Button Grid.Column="1" Content="Browse" Command="{Binding BrowseWifiCertificateCommand}" VerticalAlignment="Bottom" />
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
