<?xml version="1.0" encoding="utf-8" ?>
<Page x:Class="Foundry.Views.AppUpdateSettingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:dev="using:DevWinUI"
      xmlns:local="using:Foundry"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:views="using:Foundry.Views"
      xmlns:wct="using:CommunityToolkit.WinUI.Controls"
      dev:BreadcrumbNavigator.IsHeaderVisible="True"
      mc:Ignorable="d">
    <ScrollView Margin="{ThemeResource ContentPageMargin}"
                Padding="{ThemeResource ContentPagePadding}"
                VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="{ThemeResource FoundryPageContentInset}"
                    dev:PanelAttach.ChildrenTransitions="Default"
                    Spacing="{ThemeResource FoundrySettingsSectionSpacing}">
            <Border Background="{ThemeResource FoundrySurfaceSecondaryBrush}"
                    BorderBrush="{ThemeResource FoundrySurfaceBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{ThemeResource FoundryCardCornerRadius}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Background="{ThemeResource AccentFillColorDefaultBrush}"
                            CornerRadius="4,0,0,4" />

                    <StackPanel Grid.Column="1"
                                Padding="20">
                        <Grid ColumnSpacing="{ThemeResource FoundrySpace16}"
                              RowSpacing="{ThemeResource FoundrySpace12}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border Width="48"
                                    Height="48"
                                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                                    CornerRadius="{ThemeResource FoundryCardCornerRadius}">
                                <FontIcon FontSize="24"
                                          Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                          Glyph="&#xEBD3;" />
                            </Border>

                            <StackPanel Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Spacing="{ThemeResource FoundrySpace4}">
                                <StackPanel Orientation="Horizontal"
                                            Spacing="{ThemeResource FoundrySpace8}">
                                    <TextBlock Style="{ThemeResource FoundrySectionTitleTextBlockStyle}"
                                               Text="{x:Bind ViewModel.UpdateStatusTitle, Mode=OneWay}"
                                               TextWrapping="WrapWholeWords" />
                                    <Border Padding="8,3"
                                            VerticalAlignment="Center"
                                            Background="{ThemeResource AccentFillColorDefaultBrush}"
                                            CornerRadius="{ThemeResource FoundryControlCornerRadius}"
                                            Visibility="{x:Bind ViewModel.IsUpdateAvailable, Mode=OneWay}">
                                        <TextBlock Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                                   FontWeight="SemiBold"
                                                   Style="{ThemeResource FoundryCaptionTextBlockStyle}"
                                                   Text="{x:Bind ViewModel.UpdateNewBadgeText, Mode=OneWay}" />
                                    </Border>
                                </StackPanel>
                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Style="{ThemeResource FoundryCaptionTextBlockStyle}"
                                           Text="{x:Bind ViewModel.LoadingStatus, Mode=OneWay}"
                                           TextWrapping="WrapWholeWords" />
                            </StackPanel>

                            <Grid Grid.Row="1"
                                  Grid.Column="1"
                                  MaxWidth="960"
                                  HorizontalAlignment="Stretch"
                                  ColumnSpacing="{ThemeResource FoundrySpace12}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Padding="14,12"
                                        Background="{ThemeResource FoundrySurfaceBrush}"
                                        BorderBrush="{ThemeResource FoundrySurfaceBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="{ThemeResource FoundryControlCornerRadius}">
                                    <StackPanel Spacing="{ThemeResource FoundrySpace4}">
                                        <TextBlock Style="{ThemeResource FoundryCaptionTextBlockStyle}"
                                                   Text="{x:Bind ViewModel.InstalledVersionLabel, Mode=OneWay}" />
                                        <TextBlock FlowDirection="LeftToRight"
                                                   FontWeight="SemiBold"
                                                   Text="{x:Bind ViewModel.InstalledVersion, Mode=OneWay}"
                                                   TextWrapping="NoWrap" />
                                    </StackPanel>
                                </Border>

                                <FontIcon Grid.Column="1"
                                          VerticalAlignment="Center"
                                          FontSize="18"
                                          Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                          Glyph="&#xE72A;" />

                                <Border Grid.Column="2"
                                        Padding="14,12"
                                        Background="{ThemeResource FoundrySurfaceBrush}"
                                        BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="{ThemeResource FoundryControlCornerRadius}">
                                    <StackPanel Spacing="{ThemeResource FoundrySpace4}">
                                        <TextBlock Style="{ThemeResource FoundryCaptionTextBlockStyle}"
                                                   Text="{x:Bind ViewModel.AvailableVersionLabel, Mode=OneWay}" />
                                        <TextBlock FlowDirection="LeftToRight"
                                                   FontWeight="SemiBold"
                                                   Text="{x:Bind ViewModel.AvailableVersion, Mode=OneWay}"
                                                   TextWrapping="NoWrap" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="3"
                                        Padding="14,12"
                                        Background="{ThemeResource FoundrySurfaceBrush}"
                                        BorderBrush="{ThemeResource FoundrySurfaceBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="{ThemeResource FoundryControlCornerRadius}">
                                    <StackPanel Spacing="{ThemeResource FoundrySpace4}">
                                        <TextBlock Style="{ThemeResource FoundryCaptionTextBlockStyle}"
                                                   Text="{x:Bind ViewModel.LastUpdateCheckLabel, Mode=OneWay}" />
                                        <TextBlock FlowDirection="LeftToRight"
                                                   FontWeight="SemiBold"
                                                   Text="{x:Bind ViewModel.LastUpdateCheck, Mode=OneWay}"
                                                   TextWrapping="NoWrap" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <StackPanel Grid.Row="2"
                                        Grid.Column="1"
                                        HorizontalAlignment="Right"
                                        Orientation="Horizontal"
                                        Spacing="{ThemeResource FoundryInlineControlSpacing}">
                                <Button MinWidth="{ThemeResource FoundryCompactActionMinWidth}"
                                        x:Uid="AppUpdate_DownloadRestartButton"
                                        Click="DownloadRestartButton_Click"
                                        Style="{ThemeResource AccentButtonStyle}"
                                        Visibility="{x:Bind ViewModel.IsInstallButtonVisible, Mode=OneWay}" />
                                <Button MinWidth="{ThemeResource FoundryCompactActionMinWidth}"
                                        x:Uid="AppUpdate_ReleaseNotesLink"
                                        Click="ReleaseNotesLink_Click"
                                        Visibility="{x:Bind ViewModel.IsReleaseNotesVisible, Mode=OneWay}" />
                                <Button MinWidth="{ThemeResource FoundryCompactActionMinWidth}"
                                        x:Uid="AppUpdate_CheckButton"
                                        Command="{x:Bind ViewModel.CheckForUpdateCommand}"
                                        IsEnabled="{x:Bind ViewModel.IsCheckButtonEnabled, Mode=OneWay}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <wct:SettingsCard Header="{x:Bind ViewModel.UpdateSourceTitle, Mode=OneWay}">
                <wct:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE946;" />
                </wct:SettingsCard.HeaderIcon>
                <wct:SettingsCard.Description>
                    <StackPanel Spacing="{ThemeResource FoundrySpace2}">
                        <TextBlock FlowDirection="LeftToRight"
                                   Text="{x:Bind ViewModel.UpdateFeedUrl, Mode=OneWay}"
                                   TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </wct:SettingsCard.Description>
                <Border Padding="10,4"
                        Background="{ThemeResource FoundrySurfaceBrush}"
                        BorderBrush="{ThemeResource FoundrySurfaceBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="{ThemeResource FoundryControlCornerRadius}">
                    <TextBlock Style="{ThemeResource FoundryCaptionTextBlockStyle}"
                               Text="{x:Bind ViewModel.UpdateSourceDescription, Mode=OneWay}"
                               TextWrapping="WrapWholeWords" />
                </Border>
            </wct:SettingsCard>
        </StackPanel>
    </ScrollView>
</Page>

