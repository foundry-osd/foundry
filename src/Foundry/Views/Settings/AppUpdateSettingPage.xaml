<?xml version="1.0" encoding="utf-8" ?>
<Page x:Class="Foundry.Views.AppUpdateSettingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:dev="using:DevWinUI"
      xmlns:local="using:Foundry"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:views="using:Foundry.Views"
      xmlns:wct="using:CommunityToolkit.WinUI.Controls"
      dev:BreadcrumbNavigator.IsHeaderVisible="True"
      mc:Ignorable="d">
    <ScrollView Margin="{ThemeResource ContentPageMargin}"
                Padding="{ThemeResource ContentPagePadding}"
                VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="{ThemeResource FoundryPageContentInset}"
                    dev:PanelAttach.ChildrenTransitions="Default"
                    Spacing="{ThemeResource FoundrySettingsSectionSpacing}">
            <wct:SettingsCard Header="{x:Bind ViewModel.UpdateStatusTitle, Mode=OneWay}">
                <wct:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE895;" />
                </wct:SettingsCard.HeaderIcon>
                <wct:SettingsCard.Description>
                    <StackPanel MaxWidth="640"
                                Spacing="{ThemeResource FoundrySpace4}">
                        <TextBlock Text="{x:Bind ViewModel.LoadingStatus, Mode=OneWay}"
                                   TextWrapping="WrapWholeWords" />
                        <TextBlock FlowDirection="LeftToRight"
                                   Style="{ThemeResource FoundryCaptionTextBlockStyle}"
                                   Text="{x:Bind ViewModel.UpdateStatusMetadata, Mode=OneWay}"
                                   TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </wct:SettingsCard.Description>
                <StackPanel Orientation="Horizontal"
                            Spacing="{ThemeResource FoundryInlineControlSpacing}">
                    <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />
                    <Button MinWidth="{ThemeResource FoundryCompactActionMinWidth}"
                            x:Uid="AppUpdate_DownloadRestartButton"
                            Command="{x:Bind ViewModel.DownloadAndRestartUpdateCommand}"
                            Style="{ThemeResource AccentButtonStyle}"
                            Visibility="{x:Bind ViewModel.IsInstallButtonVisible, Mode=OneWay}" />
                    <Button MinWidth="{ThemeResource FoundryCompactActionMinWidth}"
                            x:Uid="AppUpdate_ReleaseNotesLink"
                            Click="ReleaseNotesLink_Click"
                            Visibility="{x:Bind ViewModel.IsReleaseNotesVisible, Mode=OneWay}" />
                    <Button MinWidth="{ThemeResource FoundryCompactActionMinWidth}"
                            x:Uid="AppUpdate_CheckButton"
                            Command="{x:Bind ViewModel.CheckForUpdateCommand}"
                            IsEnabled="{x:Bind ViewModel.IsCheckButtonEnabled, Mode=OneWay}" />
                    <ProgressBar Width="160"
                                 Maximum="100"
                                 Value="{x:Bind ViewModel.DownloadProgress, Mode=OneWay}"
                                 Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />
                </StackPanel>
            </wct:SettingsCard>

            <wct:SettingsCard Description="{x:Bind ViewModel.UpdateFeedUrl}"
                              Header="{x:Bind ViewModel.UpdateSourceTitle, Mode=OneWay}">
                <wct:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE946;" />
                </wct:SettingsCard.HeaderIcon>
                <TextBlock FlowDirection="LeftToRight"
                           Style="{ThemeResource FoundryCaptionTextBlockStyle}"
                           Text="{x:Bind ViewModel.UpdateSourceDescription, Mode=OneWay}" />
            </wct:SettingsCard>
        </StackPanel>
    </ScrollView>
</Page>

