<?xml version="1.0" encoding="utf-8" ?>
<Page x:Class="Foundry.Views.GeneralSettingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:dev="using:DevWinUI"
      xmlns:local="using:Foundry"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:views="using:Foundry.Views"
      xmlns:wct="using:CommunityToolkit.WinUI.Controls"
      dev:BreadcrumbNavigator.IsHeaderVisible="True"
      mc:Ignorable="d">
    <ScrollView Margin="{ThemeResource ContentPageMargin}"
                Padding="{ThemeResource ContentPagePadding}"
                VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="{ThemeResource FoundryPageContentInset}"
                    dev:PanelAttach.ChildrenTransitions="Default"
                    Spacing="{ThemeResource FoundryCompactStackSpacing}">

            <wct:SettingsCard x:Name="StartupCard"
                               x:Uid="GeneralSetting_StartupCard">
                <wct:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE7F4;" />
                </wct:SettingsCard.HeaderIcon>
                <ToggleSwitch x:Name="StartupToggle"
                               IsOn="{x:Bind dev:StartupHelper.IsAppStartupWithWindowsForXamlBindingEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </wct:SettingsCard>

            <wct:SettingsCard x:Name="LanguageCard"
                               x:Uid="GeneralSetting_LanguageCard">
                <wct:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xF2B7;" />
                </wct:SettingsCard.HeaderIcon>
                <ComboBox x:Name="LanguageComboBox"
                          MinWidth="{ThemeResource FoundryCompactActionMinWidth}"
                          ItemsSource="{x:Bind ViewModel.SupportedLanguages, Mode=OneWay}"
                          SelectedItem="{x:Bind ViewModel.SelectedLanguage, Mode=TwoWay}"
                          SelectionChanged="LanguageComboBox_SelectionChanged">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DisplayName}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </wct:SettingsCard>

            <wct:SettingsExpander x:Name="DiagnosticsCard"
                                   x:Uid="GeneralSetting_DiagnosticsCard">
                <wct:SettingsExpander.HeaderIcon>
                    <FontIcon Glyph="&#xE9D9;" />
                </wct:SettingsExpander.HeaderIcon>
                <ToggleSwitch x:Name="DiagnosticsToggle"
                               IsOn="{x:Bind ViewModel.IsDeveloperMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <wct:SettingsExpander.ItemsHeader>
                    <HyperlinkButton HorizontalAlignment="Stretch"
                                      HorizontalContentAlignment="Left"
                                      Command="{x:Bind ViewModel.OpenLogFolderCommand}"
                                      ToolTipService.ToolTip="{x:Bind ViewModel.LogDirectoryPath}">
                        <TextBlock Text="{x:Bind ViewModel.LogDirectoryPath}"
                                   TextTrimming="CharacterEllipsis" />
                    </HyperlinkButton>
                </wct:SettingsExpander.ItemsHeader>
            </wct:SettingsExpander>

        </StackPanel>
    </ScrollView>
</Page>

