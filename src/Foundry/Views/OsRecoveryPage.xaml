<?xml version="1.0" encoding="utf-8" ?>
<Page x:Class="Foundry.Views.OsRecoveryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:behaviors="using:Foundry.Behaviors"
      xmlns:controls="using:Foundry.Controls"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:wct="using:CommunityToolkit.WinUI.Controls"
      mc:Ignorable="d">
    <ScrollView Margin="{ThemeResource ContentPageMargin}"
                Padding="{ThemeResource ContentPagePadding}"
                VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="{ThemeResource FoundrySettingsSectionSpacing}">
            <controls:PageHeader Title="{x:Bind ViewModel.PageTitle, Mode=OneWay}"
                                 Description="{x:Bind ViewModel.PageDescription, Mode=OneWay}"
                                 DocumentationUrl="{x:Bind ViewModel.DocumentationUrl, Mode=OneWay}" />

            <wct:SettingsCard Header="{x:Bind ViewModel.EnableHeader, Mode=OneWay}"
                              Description="{x:Bind ViewModel.EnableDescription, Mode=OneWay}">
                <wct:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE7BA;" />
                </wct:SettingsCard.HeaderIcon>
                <ToggleSwitch behaviors:LocalizedToggleSwitch.UseLocalizedStateContent="True"
                              AutomationProperties.Name="{x:Bind ViewModel.EnableToggleText, Mode=OneWay}"
                              IsOn="{x:Bind ViewModel.IsOsRecoveryEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </wct:SettingsCard>

            <wct:SettingsCard Header="{x:Bind ViewModel.WhyHeader, Mode=OneWay}"
                              Description="{x:Bind ViewModel.WhyDescription, Mode=OneWay}">
                <wct:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE946;" />
                </wct:SettingsCard.HeaderIcon>
            </wct:SettingsCard>

            <wct:SettingsCard Header="{x:Bind ViewModel.WhenHeader, Mode=OneWay}"
                              Description="{x:Bind ViewModel.WhenDescription, Mode=OneWay}">
                <wct:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE823;" />
                </wct:SettingsCard.HeaderIcon>
            </wct:SettingsCard>

            <wct:SettingsCard Header="{x:Bind ViewModel.WinRePathHeader, Mode=OneWay}"
                              Description="{x:Bind ViewModel.WinRePathDescription, Mode=OneWay}">
                <wct:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE8B7;" />
                </wct:SettingsCard.HeaderIcon>
            </wct:SettingsCard>

            <wct:SettingsCard Header="{x:Bind ViewModel.LimitationsHeader, Mode=OneWay}"
                              Description="{x:Bind ViewModel.LimitationsDescription, Mode=OneWay}">
                <wct:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE783;" />
                </wct:SettingsCard.HeaderIcon>
            </wct:SettingsCard>

            <wct:SettingsCard Header="{x:Bind ViewModel.FlowHeader, Mode=OneWay}"
                              Description="{x:Bind ViewModel.FlowDescription, Mode=OneWay}"
                              HorizontalContentAlignment="Stretch">
                <wct:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE8FD;" />
                </wct:SettingsCard.HeaderIcon>
                <Image MaxHeight="360"
                       AutomationProperties.Name="{x:Bind ViewModel.FlowImageAutomationName, Mode=OneWay}"
                       Source="ms-appx:///Assets/OsRecovery/winre-os-recovery-flow.png"
                       Stretch="Uniform" />
            </wct:SettingsCard>
        </StackPanel>
    </ScrollView>
</Page>
