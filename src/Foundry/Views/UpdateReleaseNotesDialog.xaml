<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog x:Class="Foundry.Views.UpdateReleaseNotesDialog"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
               xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
               CornerRadius="{ThemeResource OverlayCornerRadius}"
               DefaultButton="None"
               Style="{ThemeResource DefaultContentDialogStyle}"
               mc:Ignorable="d">
    <Grid x:Name="DialogContentRoot"
          RowSpacing="{ThemeResource FoundryContentGroupSpacing}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Button Width="46"
                Height="31"
                Padding="0"
                Margin="0,-24,-24,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                AutomationProperties.Name="{Binding CloseText}"
                Background="Transparent"
                BorderThickness="0"
                Click="CloseButton_Click"
                CornerRadius="0"
                ToolTipService.ToolTip="{Binding CloseText}">
            <Button.Resources>
                <SolidColorBrush x:Key="ButtonBackgroundPointerOver"
                                 Color="#E81123" />
                <SolidColorBrush x:Key="ButtonBackgroundPressed"
                                 Color="#A80000" />
                <SolidColorBrush x:Key="ButtonForegroundPointerOver"
                                 Color="#FFFFFF" />
                <SolidColorBrush x:Key="ButtonForegroundPressed"
                                 Color="#FFFFFF" />
            </Button.Resources>
            <FontIcon FontSize="12"
                      Glyph="&#xE711;" />
        </Button>

        <Frame x:Name="ContentFrame"
               Grid.Row="1"
               Margin="10,0,10,0"
               IsNavigationStackEnabled="False" />
    </Grid>
</ContentDialog>
