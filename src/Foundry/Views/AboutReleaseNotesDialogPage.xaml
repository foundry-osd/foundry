<?xml version="1.0" encoding="utf-8" ?>
<Page x:Class="Foundry.Views.AboutReleaseNotesDialogPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      NavigationCacheMode="Disabled"
      mc:Ignorable="d">
    <Grid Margin="{ThemeResource FoundryDialogPageMargin}">
        <WebView2 x:Name="ReleaseNotesWebView"
                  CoreWebView2Initialized="ReleaseNotesWebView_CoreWebView2Initialized"
                  NavigationCompleted="ReleaseNotesWebView_NavigationCompleted"
                  NavigationStarting="ReleaseNotesWebView_NavigationStarting" />

        <StackPanel x:Name="ReleaseNotesLoadingPanel"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="{ThemeResource FoundryContentGroupSpacing}">
            <ProgressRing Width="40"
                          Height="40"
                          IsActive="True" />
            <TextBlock Text="{Binding ReleaseNotesLoadingText}" />
        </StackPanel>

        <StackPanel x:Name="ReleaseNotesErrorPanel"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="{ThemeResource FoundryContentGroupSpacing}"
                    Visibility="Collapsed">
            <FontIcon FontSize="{ThemeResource FoundryIconSizeHero}"
                      Glyph="&#xE783;" />
            <TextBlock Text="{Binding ReleaseNotesErrorText}"
                       TextWrapping="WrapWholeWords" />
            <HyperlinkButton Content="{Binding OpenReleaseNotesText}"
                             NavigateUri="{Binding ReleasesUri}" />
        </StackPanel>
    </Grid>
</Page>
