<?xml version="1.0" encoding="utf-8" ?>
<Page x:Class="Foundry.Views.CustomizationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:wct="using:CommunityToolkit.WinUI.Controls"
      mc:Ignorable="d">
    <ScrollView Margin="{ThemeResource ContentPageMargin}"
                Padding="{ThemeResource ContentPagePadding}"
                VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="{ThemeResource FoundryPageContentInset}"
                    Spacing="{ThemeResource FoundrySettingsSectionSpacing}">
            <TextBlock Text="{x:Bind ViewModel.PageTitle, Mode=OneWay}"
                       Style="{ThemeResource FoundryPageTitleTextBlockStyle}" />

            <wct:SettingsExpander Header="{x:Bind ViewModel.MachineNamingHeader, Mode=OneWay}"
                                  Description="{x:Bind ViewModel.MachineNamingDescription, Mode=OneWay}"
                                  IsExpanded="True">
                <wct:SettingsExpander.HeaderIcon>
                    <FontIcon Glyph="&#xE8D4;" />
                </wct:SettingsExpander.HeaderIcon>
                <ToggleSwitch AutomationProperties.Name="{x:Bind ViewModel.MachineNamingEnableText, Mode=OneWay}"
                              IsOn="{x:Bind ViewModel.IsMachineNamingEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <wct:SettingsExpander.Items>
                    <wct:SettingsCard Header="{x:Bind ViewModel.MachineNamingPrefixLabel, Mode=OneWay}"
                                      Description="{x:Bind ViewModel.MachineNamingPrefixDescription, Mode=OneWay}"
                                      HorizontalContentAlignment="Stretch"
                                      IsEnabled="{x:Bind ViewModel.IsMachineNamingOptionsEnabled, Mode=OneWay}">
                        <StackPanel HorizontalAlignment="Right"
                                    Spacing="{ThemeResource FoundrySpace4}">
                            <TextBox Width="{ThemeResource FoundryWideInputMinWidth}"
                                     MaxLength="{x:Bind ViewModel.MachineNamePrefixMaxLength, Mode=OneWay}"
                                     Text="{x:Bind ViewModel.MachineNamePrefix, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                       Text="{x:Bind ViewModel.MachineNamePrefixValidationMessage, Mode=OneWay}"
                                       TextWrapping="WrapWholeWords"
                                       Visibility="{x:Bind ViewModel.MachineNamePrefixValidationVisibility, Mode=OneWay}" />
                        </StackPanel>
                    </wct:SettingsCard>
                    <wct:SettingsCard Header="{x:Bind ViewModel.MachineNamingAutoGenerateText, Mode=OneWay}"
                                      Description="{x:Bind ViewModel.MachineNamingAutoGenerateDescription, Mode=OneWay}"
                                      IsEnabled="{x:Bind ViewModel.IsMachineNamingOptionsEnabled, Mode=OneWay}">
                        <ToggleSwitch IsOn="{x:Bind ViewModel.MachineNameAutoGenerate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </wct:SettingsCard>
                    <wct:SettingsCard Header="{x:Bind ViewModel.MachineNamingAllowManualSuffixEditText, Mode=OneWay}"
                                      Description="{x:Bind ViewModel.MachineNamingAllowManualSuffixEditDescription, Mode=OneWay}"
                                      IsEnabled="{x:Bind ViewModel.IsMachineNamingOptionsEnabled, Mode=OneWay}">
                        <ToggleSwitch IsOn="{x:Bind ViewModel.AllowManualSuffixEdit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </wct:SettingsCard>
                </wct:SettingsExpander.Items>
            </wct:SettingsExpander>
        </StackPanel>
    </ScrollView>
</Page>
