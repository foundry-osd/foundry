<?xml version="1.0" encoding="utf-8" ?>
<Page x:Class="Foundry.Views.CustomizationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:wct="using:CommunityToolkit.WinUI.Controls"
      mc:Ignorable="d">
    <ScrollView Margin="{ThemeResource ContentPageMargin}"
                Padding="{ThemeResource ContentPagePadding}"
                VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="{ThemeResource FoundryPageContentInset}"
                    Spacing="{ThemeResource FoundrySettingsSectionSpacing}">
            <TextBlock Text="{x:Bind ViewModel.PageTitle, Mode=OneWay}"
                       Style="{ThemeResource FoundryPageTitleTextBlockStyle}" />

            <wct:SettingsExpander Header="{x:Bind ViewModel.MachineNamingHeader, Mode=OneWay}"
                                  Description="{x:Bind ViewModel.MachineNamingDescription, Mode=OneWay}"
                                  IsExpanded="{x:Bind ViewModel.IsMachineNamingExpanded, Mode=TwoWay}">
                <wct:SettingsExpander.HeaderIcon>
                    <FontIcon Glyph="&#xE8AC;" />
                </wct:SettingsExpander.HeaderIcon>
                <ToggleSwitch AutomationProperties.Name="{x:Bind ViewModel.MachineNamingEnableText, Mode=OneWay}"
                              IsOn="{x:Bind ViewModel.IsMachineNamingEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <wct:SettingsExpander.Items>
                    <wct:SettingsCard Header="{x:Bind ViewModel.MachineNamingPrefixLabel, Mode=OneWay}"
                                      Description="{x:Bind ViewModel.MachineNamingPrefixDescription, Mode=OneWay}"
                                      HorizontalContentAlignment="Stretch"
                                      IsEnabled="{x:Bind ViewModel.IsMachineNamingOptionsEnabled, Mode=OneWay}">
                        <StackPanel HorizontalAlignment="Right"
                                    Spacing="{ThemeResource FoundrySpace4}">
                            <TextBox Width="{ThemeResource FoundryWideInputMinWidth}"
                                     MaxLength="{x:Bind ViewModel.MachineNamePrefixMaxLength, Mode=OneWay}"
                                     Text="{x:Bind ViewModel.MachineNamePrefix, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                       Text="{x:Bind ViewModel.MachineNamePrefixValidationMessage, Mode=OneWay}"
                                       TextWrapping="WrapWholeWords"
                                       Visibility="{x:Bind ViewModel.MachineNamePrefixValidationVisibility, Mode=OneWay}" />
                        </StackPanel>
                    </wct:SettingsCard>
                    <wct:SettingsCard Header="{x:Bind ViewModel.MachineNamingAutoGenerateText, Mode=OneWay}"
                                      Description="{x:Bind ViewModel.MachineNamingAutoGenerateDescription, Mode=OneWay}"
                                      IsEnabled="{x:Bind ViewModel.IsMachineNamingOptionsEnabled, Mode=OneWay}">
                        <ToggleSwitch IsOn="{x:Bind ViewModel.MachineNameAutoGenerate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </wct:SettingsCard>
                    <wct:SettingsCard Header="{x:Bind ViewModel.MachineNamingAllowManualSuffixEditText, Mode=OneWay}"
                                      Description="{x:Bind ViewModel.MachineNamingAllowManualSuffixEditDescription, Mode=OneWay}"
                                      IsEnabled="{x:Bind ViewModel.IsMachineNamingOptionsEnabled, Mode=OneWay}">
                        <ToggleSwitch IsOn="{x:Bind ViewModel.AllowManualSuffixEdit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </wct:SettingsCard>
                </wct:SettingsExpander.Items>
            </wct:SettingsExpander>

            <wct:SettingsExpander Header="{x:Bind ViewModel.OobeHeader, Mode=OneWay}"
                                  Description="{x:Bind ViewModel.OobeDescription, Mode=OneWay}"
                                  IsExpanded="{x:Bind ViewModel.IsOobeExpanded, Mode=TwoWay}">
                <wct:SettingsExpander.HeaderIcon>
                    <FontIcon Glyph="&#xE713;" />
                </wct:SettingsExpander.HeaderIcon>
                <ToggleSwitch AutomationProperties.Name="{x:Bind ViewModel.OobeEnableText, Mode=OneWay}"
                              IsOn="{x:Bind ViewModel.IsOobeEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <wct:SettingsExpander.Items>
                    <wct:SettingsCard Header="{x:Bind ViewModel.OobeSkipLicenseTermsLabel, Mode=OneWay}"
                                      Description="{x:Bind ViewModel.OobeSkipLicenseTermsDescription, Mode=OneWay}"
                                      IsEnabled="{x:Bind ViewModel.IsOobeOptionsEnabled, Mode=OneWay}">
                        <ToggleSwitch IsOn="{x:Bind ViewModel.SkipLicenseTerms, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </wct:SettingsCard>
                    <wct:SettingsCard Header="{x:Bind ViewModel.OobeDiagnosticDataLabel, Mode=OneWay}"
                                      Description="{x:Bind ViewModel.OobeDiagnosticDataDescription, Mode=OneWay}"
                                      IsEnabled="{x:Bind ViewModel.IsOobeOptionsEnabled, Mode=OneWay}">
                        <ComboBox Width="{ThemeResource FoundryWideInputMinWidth}"
                                  DisplayMemberPath="DisplayName"
                                  ItemsSource="{x:Bind ViewModel.OobeDiagnosticDataOptions, Mode=OneWay}"
                                  SelectedItem="{x:Bind ViewModel.SelectedOobeDiagnosticData, Mode=TwoWay}" />
                    </wct:SettingsCard>
                    <wct:SettingsCard Header="{x:Bind ViewModel.OobeHidePrivacySetupLabel, Mode=OneWay}"
                                      Description="{x:Bind ViewModel.OobeHidePrivacySetupDescription, Mode=OneWay}"
                                      IsEnabled="{x:Bind ViewModel.IsOobeOptionsEnabled, Mode=OneWay}">
                        <ToggleSwitch IsOn="{x:Bind ViewModel.HidePrivacySetup, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </wct:SettingsCard>
                    <wct:SettingsCard Header="{x:Bind ViewModel.OobeTailoredExperiencesLabel, Mode=OneWay}"
                                      Description="{x:Bind ViewModel.OobeTailoredExperiencesDescription, Mode=OneWay}"
                                      IsEnabled="{x:Bind ViewModel.IsOobeOptionsEnabled, Mode=OneWay}">
                        <ToggleSwitch IsOn="{x:Bind ViewModel.AllowTailoredExperiences, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </wct:SettingsCard>
                    <wct:SettingsCard Header="{x:Bind ViewModel.OobeAdvertisingIdLabel, Mode=OneWay}"
                                      Description="{x:Bind ViewModel.OobeAdvertisingIdDescription, Mode=OneWay}"
                                      IsEnabled="{x:Bind ViewModel.IsOobeOptionsEnabled, Mode=OneWay}">
                        <ToggleSwitch IsOn="{x:Bind ViewModel.AllowAdvertisingId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </wct:SettingsCard>
                    <wct:SettingsCard Header="{x:Bind ViewModel.OobeOnlineSpeechRecognitionLabel, Mode=OneWay}"
                                      Description="{x:Bind ViewModel.OobeOnlineSpeechRecognitionDescription, Mode=OneWay}"
                                      IsEnabled="{x:Bind ViewModel.IsOobeOptionsEnabled, Mode=OneWay}">
                        <ToggleSwitch IsOn="{x:Bind ViewModel.AllowOnlineSpeechRecognition, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </wct:SettingsCard>
                    <wct:SettingsCard Header="{x:Bind ViewModel.OobeInkingAndTypingDiagnosticsLabel, Mode=OneWay}"
                                      Description="{x:Bind ViewModel.OobeInkingAndTypingDiagnosticsDescription, Mode=OneWay}"
                                      IsEnabled="{x:Bind ViewModel.IsOobeOptionsEnabled, Mode=OneWay}">
                        <ToggleSwitch IsOn="{x:Bind ViewModel.AllowInkingAndTypingDiagnostics, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </wct:SettingsCard>
                    <wct:SettingsCard Header="{x:Bind ViewModel.OobeLocationAccessLabel, Mode=OneWay}"
                                      Description="{x:Bind ViewModel.OobeLocationAccessDescription, Mode=OneWay}"
                                      IsEnabled="{x:Bind ViewModel.IsOobeOptionsEnabled, Mode=OneWay}">
                        <ComboBox Width="{ThemeResource FoundryWideInputMinWidth}"
                                  DisplayMemberPath="DisplayName"
                                  ItemsSource="{x:Bind ViewModel.OobeLocationAccessOptions, Mode=OneWay}"
                                  SelectedItem="{x:Bind ViewModel.SelectedOobeLocationAccess, Mode=TwoWay}" />
                    </wct:SettingsCard>
                </wct:SettingsExpander.Items>
            </wct:SettingsExpander>
        </StackPanel>
    </ScrollView>
</Page>
