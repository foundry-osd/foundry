<?xml version="1.0" encoding="utf-8" ?>
<ContentDialog x:Class="Foundry.Views.UpdateInstallProgressDialog"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
               xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
               CornerRadius="{ThemeResource OverlayCornerRadius}"
               DefaultButton="None"
               Style="{ThemeResource DefaultContentDialogStyle}"
               Title="{Binding InstallProgressDialogTitle}"
               mc:Ignorable="d">
    <StackPanel Width="420"
                Spacing="{ThemeResource FoundryContentGroupSpacing}">
        <StackPanel Orientation="Horizontal"
                    Spacing="{ThemeResource FoundrySpace16}">
            <Border Width="44"
                    Height="44"
                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                    CornerRadius="{ThemeResource FoundryCardCornerRadius}">
                <FontIcon FontSize="22"
                          Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                          Glyph="&#xEBD3;" />
            </Border>

            <StackPanel VerticalAlignment="Center"
                        Spacing="{ThemeResource FoundrySpace4}">
                <TextBlock Text="{Binding InstallProgressDialogMessage}"
                           TextWrapping="WrapWholeWords" />
                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Style="{ThemeResource FoundryCaptionTextBlockStyle}"
                           Text="{Binding LoadingStatus}"
                           TextWrapping="WrapWholeWords" />
            </StackPanel>
        </StackPanel>

        <ProgressBar Maximum="100"
                     Value="{Binding DownloadProgress}" />

        <TextBlock HorizontalAlignment="Right"
                   FlowDirection="LeftToRight"
                   FontWeight="SemiBold"
                   Text="{Binding DownloadProgressText}" />
    </StackPanel>
</ContentDialog>
