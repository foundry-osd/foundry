<Page
    x:Class="Foundry.Views.ConfigurationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel Padding="32" Spacing="16" MaxWidth="980">
            <TextBlock Text="Configuration" Style="{ThemeResource TitleTextBlockStyle}" />
            <TextBlock Text="Media and WinPE inputs" Style="{ThemeResource SubtitleTextBlockStyle}" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <TextBox Header="ISO output path" Text="{Binding IsoOutputPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <Button Grid.Column="1" Content="Browse" Command="{Binding BrowseIsoOutputPathCommand}" VerticalAlignment="Bottom" />
            </Grid>
            <ComboBox Header="Architecture" ItemsSource="{Binding AvailableArchitectures}" SelectedItem="{Binding SelectedArchitecture, Mode=TwoWay}" />
            <ComboBox Header="WinPE language" ItemsSource="{Binding AvailableWinPeLanguages}" SelectedItem="{Binding SelectedWinPeLanguage, Mode=TwoWay}" DisplayMemberPath="DisplayName" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <TextBox Header="Custom driver directory" Text="{Binding CustomDriverDirectoryPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <Button Grid.Column="1" Content="Browse" Command="{Binding BrowseCustomDriverDirectoryCommand}" VerticalAlignment="Bottom" />
            </Grid>
            <StackPanel Orientation="Horizontal" Spacing="16">
                <CheckBox Content="Dell drivers" IsChecked="{Binding IncludeDellDrivers, Mode=TwoWay}" />
                <CheckBox Content="HP drivers" IsChecked="{Binding IncludeHpDrivers, Mode=TwoWay}" />
                <CheckBox Content="CA 2023 signatures" IsChecked="{Binding UseCa2023, Mode=TwoWay}" />
            </StackPanel>
            <ComboBox Header="USB disk" ItemsSource="{Binding UsbDiskCandidates}" SelectedItem="{Binding SelectedUsbDiskCandidate, Mode=TwoWay}" />
            <ComboBox Header="USB partition style" ItemsSource="{Binding AvailablePartitionStyles}" SelectedItem="{Binding SelectedPartitionStyle, Mode=TwoWay}" />
            <ComboBox Header="USB format mode" ItemsSource="{Binding AvailableUsbFormatModes}" SelectedItem="{Binding SelectedUsbFormatMode, Mode=TwoWay}" DisplayMemberPath="DisplayName" />
            <Button Content="Refresh USB disks" Command="{Binding RefreshUsbCandidatesCommand}" />
        </StackPanel>
    </ScrollViewer>
</Page>
