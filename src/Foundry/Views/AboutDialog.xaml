<Window
    x:Class="Foundry.Views.AboutDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="{Binding Strings[AboutTitle], Mode=OneWay}"
    SizeToContent="WidthAndHeight"
    MinWidth="640"
    MinHeight="380"
    Icon="/Assets/Icons/app.ico"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterOwner">
    <Window.InputBindings>
        <KeyBinding
            Key="Escape"
            Command="{Binding CloseCommand}" />
    </Window.InputBindings>

    <Grid Margin="24,22,24,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="28" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Image
                Grid.Column="0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Source="/Assets/Images/foundry-about-logo.png"
                Stretch="Uniform" />

            <StackPanel Grid.Column="2">
                <TextBlock
                    FontSize="54"
                    FontWeight="Light"
                    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                    Text="{Binding AppName}" />

                <TextBlock
                    Margin="0,12,0,0"
                    FontSize="18"
                    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                    Text="{Binding Version}" />

                <TextBlock
                    Margin="0,20,0,0"
                    Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                    <Run Text="{Binding Strings[AboutCheckForUpdatesLabel], Mode=OneWay}" />
                    <Run Text=" " />
                    <Hyperlink Command="{Binding CheckForUpdatesCommand}">
                        <Run Text="{Binding CheckForUpdatesLinkText, Mode=OneWay}" />
                    </Hyperlink>
                </TextBlock>

                <TextBlock
                    Margin="0,20,0,0"
                    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                    Text="{Binding Strings[AboutDescriptionLine1], Mode=OneWay}"
                    TextWrapping="Wrap" />

                <TextBlock
                    Margin="0,10,0,0"
                    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                    Text="{Binding Strings[AboutDescriptionLine2], Mode=OneWay}"
                    TextWrapping="Wrap" />

                <TextBlock
                    Margin="0,20,0,0"
                    Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                    <Hyperlink Command="{Binding OpenLicenseCommand}">
                        <Run Text="{Binding Strings[AboutLicenseLink], Mode=OneWay}" />
                    </Hyperlink>
                    <Run Text=" | " />
                    <Hyperlink Command="{Binding OpenAuthorsCommand}">
                        <Run Text="{Binding Strings[AboutAuthorsLink], Mode=OneWay}" />
                    </Hyperlink>
                    <Run Text=" | " />
                    <Hyperlink Command="{Binding OpenSupportCommand}">
                        <Run Text="{Binding Strings[AboutSupportLink], Mode=OneWay}" />
                    </Hyperlink>
                </TextBlock>
            </StackPanel>
        </Grid>

        <TextBlock
            Grid.Row="1"
            Margin="0,16,0,0"
            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
            Style="{StaticResource CaptionTextBlockStyle}"
            Text="{Binding Strings[AboutFooter], Mode=OneWay}"
            TextWrapping="Wrap" />
    </Grid>
</Window>
