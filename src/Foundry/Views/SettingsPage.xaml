<?xml version="1.0" encoding="utf-8" ?>
<Page x:Class="Foundry.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:dev="using:DevWinUI"
      xmlns:local="using:Foundry"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:wct="using:CommunityToolkit.WinUI.Controls"
      xmlns:views="using:Foundry.Views"
      dev:BreadcrumbNavigator.IsHeaderVisible="True"
      mc:Ignorable="d">
    <ScrollView Margin="{ThemeResource ContentPageMargin}"
                Padding="{ThemeResource ContentPagePadding}"
                HorizontalAlignment="Stretch"
                VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="{ThemeResource FoundryPageContentInset}"
                    dev:PanelAttach.ChildrenTransitions="Default"
                    Spacing="{ThemeResource FoundryCompactStackSpacing}">
            <wct:SettingsCard x:Name="GeneralSettingsCard"
                              x:Uid="SettingsPage_GeneralCard"
                              IsClickEnabled="True"
                              Command="{x:Bind local:App.Current.NavService.NavigateToCommand}">
                <wct:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE713;" />
                </wct:SettingsCard.HeaderIcon>
            </wct:SettingsCard>
            <wct:SettingsCard x:Name="TelemetryCard"
                              x:Uid="SettingsPage_TelemetryCard">
                <wct:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE9D9;" />
                </wct:SettingsCard.HeaderIcon>
                <ToggleSwitch x:Name="TelemetryToggle"
                              IsOn="{x:Bind ViewModel.IsTelemetryEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </wct:SettingsCard>
            <wct:SettingsCard x:Name="ThemeSettingsCard"
                              x:Uid="SettingsPage_ThemeCard"
                              IsClickEnabled="True"
                              Command="{x:Bind local:App.Current.NavService.NavigateToCommand}">
                <wct:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE790;" />
                </wct:SettingsCard.HeaderIcon>
            </wct:SettingsCard>
            <wct:SettingsCard x:Name="UpdateSettingsCard"
                              x:Uid="SettingsPage_UpdateCard"
                              IsClickEnabled="True"
                              Command="{x:Bind local:App.Current.NavService.NavigateToCommand}">
                <wct:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE895;" />
                </wct:SettingsCard.HeaderIcon>
            </wct:SettingsCard>
        </StackPanel>
    </ScrollView>
</Page>

