<Page
    x:Class="Foundry.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel x:Name="Root" Padding="32" Spacing="12" MaxWidth="900">
            <TextBlock Text="Settings" Style="{ThemeResource TitleTextBlockStyle}" />
            <TextBlock Text="Appearance" Style="{ThemeResource SubtitleTextBlockStyle}" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="System" Command="{Binding SetSystemThemeCommand}" />
                <Button Content="Light" Command="{Binding SetLightThemeCommand}" />
                <Button Content="Dark" Command="{Binding SetDarkThemeCommand}" />
            </StackPanel>
            <TextBlock Text="Maintenance" Style="{ThemeResource SubtitleTextBlockStyle}" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Check for updates" Command="{Binding CheckForUpdatesCommand}" />
                <Button Content="Open logs folder" Command="{Binding OpenLogFolderCommand}" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
