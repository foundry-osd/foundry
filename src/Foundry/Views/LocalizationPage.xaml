<Page
    x:Class="Foundry.Views.LocalizationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel Padding="32" Spacing="16" MaxWidth="980">
            <TextBlock Text="Localization" Style="{ThemeResource TitleTextBlockStyle}" />
            <CheckBox Content="Force a single visible deployment language" IsChecked="{Binding ForceSingleVisibleLanguage, Mode=TwoWay}" />
            <ComboBox Header="Default deployment language" ItemsSource="{Binding VisibleLanguages}" SelectedValue="{Binding SelectedDefaultLanguageCode, Mode=TwoWay}" SelectedValuePath="Code" DisplayMemberPath="DisplayName" />
            <ComboBox Header="Time zone" ItemsSource="{Binding AvailableTimeZones}" SelectedValue="{Binding SelectedTimeZoneId, Mode=TwoWay}" SelectedValuePath="Id" DisplayMemberPath="DisplayName" />
            <ListView Header="Visible deployment languages" ItemsSource="{Binding AvailableLanguages}" SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <CheckBox Content="{Binding DisplayName}" IsChecked="{Binding IsSelected, Mode=TwoWay}" />
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </StackPanel>
    </ScrollViewer>
</Page>
