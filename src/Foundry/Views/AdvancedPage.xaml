<Page
    x:Class="Foundry.Views.AdvancedPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Foundry.Views.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Advanced"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  ADK Banner  -->
        <controls:AdkBanner x:Name="AdkBannerControl" Grid.Row="0" />

        <!--  Main Content  -->
        <Grid Grid.Row="1" Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  Action Buttons  -->
            <StackPanel
                Grid.Row="0"
                Margin="0,0,0,16"
                Orientation="Horizontal">
                <Button
                    Width="120"
                    Margin="0,0,8,0"
                    Command="{Binding CreateIsoCommand}"
                    Content="{Binding Strings[CreateIso]}" />

                <Button
                    Width="120"
                    Command="{Binding CreateUsbCommand}"
                    Content="{Binding Strings[CreateUsb]}" />
            </StackPanel>

            <!--  Placeholder Content  -->
            <TextBlock
                Grid.Row="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                Style="{StaticResource TitleTextBlockStyle}"
                Text="Advanced" />
        </Grid>
    </Grid>
</Page>
