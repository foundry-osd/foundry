<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="FoundryPageTitleTextBlockStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource TitleTextBlockStyle}" />
    <Style x:Key="FoundrySectionTitleTextBlockStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource SubtitleTextBlockStyle}" />
    <Style x:Key="FoundryBodyTextBlockStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource BodyTextBlockStyle}" />
    <Style x:Key="FoundryCaptionTextBlockStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource CaptionTextBlockStyle}" />
</ResourceDictionary>
