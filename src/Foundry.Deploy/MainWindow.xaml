<Window
    x:Class="Foundry.Deploy.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Foundry.Deploy"
    Width="1080"
    Height="760"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Menu Grid.Row="0">
            <MenuItem Header="_Theme">
                <MenuItem Command="{Binding SetSystemThemeCommand}" Header="System" />
                <MenuItem Command="{Binding SetLightThemeCommand}" Header="Light" />
                <MenuItem Command="{Binding SetDarkThemeCommand}" Header="Dark" />
            </MenuItem>
            <MenuItem Header="_Tools">
                <MenuItem Command="{Binding RefreshCatalogsCommand}" Header="Refresh Catalogs" />
                <MenuItem Command="{Binding RefreshTargetDisksCommand}" Header="Refresh Target Disks" />
                <MenuItem Command="{Binding OpenLogsFolderCommand}" Header="Open Logs Folder" />
            </MenuItem>
        </Menu>

        <Grid Grid.Row="1" Margin="16">
            <Grid Visibility="{Binding ShowProgressPage, Converter={StaticResource InverseBooleanConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock
                        FontSize="20"
                        FontWeight="SemiBold"
                        Text="Foundry.Deploy Wizard" />
                    <Border
                        Margin="0,8,0,0"
                        Padding="8"
                        Background="#33FFAA00"
                        BorderBrush="#FFFFAA00"
                        BorderThickness="1"
                        CornerRadius="4"
                        Visibility="{Binding IsDebugSafeMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock
                            FontWeight="SemiBold"
                            Text="DEBUG SAFE MODE ACTIVE: all deployment actions are simulated, no disk/image write is executed." />
                    </Border>
                    <TextBlock
                        Margin="0,6,0,0"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="Task-sequence orchestrator for OS deployment in WinPE." />
                    <TextBlock
                        Margin="0,6,0,0"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="{Binding DetectedHardwareSummary}" />
                </StackPanel>

                <TabControl Grid.Row="1" IsEnabled="False" SelectedIndex="{Binding WizardStepIndex}">
                    <TabItem Header="1. Mode">
                        <Grid Margin="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock FontWeight="SemiBold" Text="Deployment Mode" />
                            <ComboBox
                                Grid.Row="1"
                                Margin="0,6,0,16"
                                ItemsSource="{Binding DeploymentModes}"
                                SelectedItem="{Binding SelectedDeploymentMode}" />

                            <StackPanel Grid.Row="2">
                                <TextBlock FontWeight="SemiBold" Text="Cache Root" />
                                <TextBox Margin="0,6,0,0" Text="{Binding CacheRootPath}" />
                                <TextBlock
                                    Margin="0,6,0,0"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                    Text="ISO mode uses C:\Foundry\Deploy. USB mode will switch to cache partition logic in the deployment engine." />
                                <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="Target Disk" />
                                <DockPanel Margin="0,6,0,0">
                                    <ComboBox
                                        Width="640"
                                        DisplayMemberPath="DisplayLabel"
                                        ItemsSource="{Binding TargetDisks}"
                                        SelectedItem="{Binding SelectedTargetDisk}" />
                                    <Button
                                        Width="140"
                                        Margin="8,0,0,0"
                                        Command="{Binding RefreshTargetDisksCommand}"
                                        Content="Refresh Disks" />
                                </DockPanel>
                                <TextBlock
                                    Margin="0,6,0,0"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                    Text="{Binding SelectedTargetDisk.SelectionWarning, TargetNullValue=Select a target disk. Non-eligible disks are blocked.}" />
                                <CheckBox
                                    Margin="0,12,0,0"
                                    IsChecked="{Binding AutoSelectDriverPackWhenEmpty}">
                                    <TextBlock Text="Auto-select driver pack based on detected hardware." />
                                </CheckBox>
                                <CheckBox
                                    Margin="0,8,0,0"
                                    IsChecked="{Binding UseFullAutopilot}">
                                    <TextBlock Text="Autopilot: Full workflow enabled (V1 scope)." />
                                </CheckBox>
                                <CheckBox
                                    Margin="0,8,0,0"
                                    IsChecked="{Binding AllowAutopilotDeferredCompletion}">
                                    <TextBlock Text="Autopilot: Defer completion if online enrollment fails." />
                                </CheckBox>
                            </StackPanel>
                        </Grid>
                    </TabItem>

                    <TabItem Header="2. OS Catalog">
                        <Grid Margin="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <DockPanel Margin="0,0,0,8">
                                <TextBox
                                    Width="420"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"
                                    Text="{Binding OsSearchText, UpdateSourceTrigger=PropertyChanged}" />
                                <Button
                                    Width="140"
                                    Command="{Binding RefreshCatalogsCommand}"
                                    Content="Refresh Catalogs" />
                            </DockPanel>

                            <ListBox
                                Grid.Row="1"
                                DisplayMemberPath="DisplayLabel"
                                ItemsSource="{Binding FilteredOperatingSystems}"
                                SelectedItem="{Binding SelectedOperatingSystem}" />
                        </Grid>
                    </TabItem>

                    <TabItem Header="3. Driver Catalog">
                        <Grid Margin="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBox
                                Margin="0,0,0,8"
                                Text="{Binding DriverPackSearchText, UpdateSourceTrigger=PropertyChanged}" />

                            <ListBox
                                Grid.Row="1"
                                DisplayMemberPath="DisplayLabel"
                                ItemsSource="{Binding FilteredDriverPacks}"
                                SelectedItem="{Binding SelectedDriverPack}" />
                        </Grid>
                    </TabItem>

                    <TabItem Header="4. Summary">
                        <StackPanel Margin="12">
                            <TextBlock
                                Margin="0,0,0,12"
                                FontSize="16"
                                FontWeight="SemiBold"
                                Text="Deployment Summary" />

                            <TextBlock FontWeight="SemiBold" Text="Mode" />
                            <TextBlock Margin="0,0,0,8" Text="{Binding SelectedDeploymentMode}" />

                            <TextBlock FontWeight="SemiBold" Text="Cache Root" />
                            <TextBlock Margin="0,0,0,8" Text="{Binding CacheRootPath}" />

                            <TextBlock FontWeight="SemiBold" Text="Target Disk" />
                            <TextBlock Margin="0,0,0,8" Text="{Binding SelectedTargetDisk.DisplayLabel, TargetNullValue=No disk selected}" />

                            <TextBlock FontWeight="SemiBold" Text="Selected Operating System" />
                            <TextBlock Margin="0,0,0,8" Text="{Binding SelectedOperatingSystem.DisplayLabel, TargetNullValue=No selection}" />

                            <TextBlock FontWeight="SemiBold" Text="Selected Driver Pack" />
                            <TextBlock Margin="0,0,0,8" Text="{Binding SelectedDriverPack.DisplayLabel, TargetNullValue=None}" />

                            <TextBlock FontWeight="SemiBold" Text="Driver Pack Mode" />
                            <TextBlock
                                Margin="0,0,0,8"
                                Text="{Binding AutoSelectDriverPackWhenEmpty, StringFormat=Auto-select when empty: {0}}" />

                            <TextBlock FontWeight="SemiBold" Text="Autopilot" />
                            <TextBlock
                                Margin="0,0,0,8"
                                Text="{Binding UseFullAutopilot, StringFormat=Full workflow enabled: {0}}" />

                            <TextBlock FontWeight="SemiBold" Text="Autopilot Fallback" />
                            <TextBlock
                                Margin="0,0,0,8"
                                Text="{Binding AllowAutopilotDeferredCompletion, StringFormat=Deferred completion allowed: {0}}" />

                            <TextBlock
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                Text="Start launches the deployment task sequence orchestrator with real WinPE actions (diskpart, DISM, BCDBoot, driver injection, Autopilot workflow)." />
                            <TextBlock
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                Visibility="{Binding IsDebugSafeMode, Converter={StaticResource BooleanToVisibilityConverter}}"
                                Text="Debug Safe Mode: task sequence runs in dry-run simulation." />
                        </StackPanel>
                    </TabItem>
                </TabControl>

                <StackPanel
                    Grid.Row="2"
                    Margin="0,12,0,0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
                    <Button
                        Width="120"
                        Margin="0,0,8,0"
                        Command="{Binding PreviousWizardStepCommand}"
                        Content="Previous" />
                    <Button
                        Width="120"
                        Margin="0,0,8,0"
                        Command="{Binding NextWizardStepCommand}"
                        Content="Next" />
                    <Button
                        Width="160"
                        Command="{Binding StartDeploymentCommand}"
                        Content="Start Deployment" />
                </StackPanel>
            </Grid>

            <Grid Visibility="{Binding ShowProgressPage, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="2*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock
                    FontSize="20"
                    FontWeight="SemiBold"
                    Text="Deployment Progress" />

                <StackPanel Grid.Row="1" Margin="0,8,0,12">
                    <ProgressBar Height="18" Maximum="100" Value="{Binding DeploymentProgress}" />
                    <TextBlock Margin="0,6,0,0" Text="{Binding DeploymentStatus}" />
                </StackPanel>

                <GroupBox Grid.Row="2" Header="Steps">
                    <ListBox ItemsSource="{Binding DeploymentSteps}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Grid.Column="0"
                                        FontWeight="SemiBold"
                                        Text="{Binding State}" />
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding StepName}" />
                                        <TextBlock
                                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                            Text="{Binding Message}" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </GroupBox>

                <GroupBox Grid.Row="3" Margin="0,12,0,0" Header="Logs">
                    <ListBox ItemsSource="{Binding DeploymentLogs}" />
                </GroupBox>

                <StackPanel
                    Grid.Row="4"
                    Margin="0,12,0,0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
                    <Button
                        Width="140"
                        Margin="0,0,8,0"
                        Command="{Binding OpenLogsFolderCommand}"
                        Content="Open Logs Folder" />
                    <Button
                        Width="140"
                        Command="{Binding ResetWizardCommand}"
                        Content="Back To Wizard" />
                </StackPanel>
            </Grid>
        </Grid>

        <StatusBar Grid.Row="2">
            <StatusBarItem Content="{Binding DeploymentStatus}" />
        </StatusBar>
    </Grid>
</Window>
