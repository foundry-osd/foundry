<UserControl
    x:Class="Foundry.Connect.Views.EthernetOnlyView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource SectionCardBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Margin="0,0,16,0"
                    VerticalAlignment="Top"
                    FontFamily="Segoe Fluent Icons"
                    FontSize="28"
                    Text="{Binding EthernetGlyph}" />

                <StackPanel Grid.Column="1">
                    <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="Ethernet status" />
                    <TextBlock
                        Margin="0,8,0,0"
                        Style="{StaticResource BodyTextBlockStyle}"
                        Text="{Binding EthernetStatusText}"
                        TextWrapping="Wrap" />
                    <TextBlock
                        Margin="0,8,0,0"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource BodyTextBlockStyle}"
                        Text="{Binding InternetStatusText}"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource SectionCardBorderStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="Network details" />
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="Adapter" />
                        <TextBlock
                            Grid.Column="1"
                            Style="{StaticResource BodyTextBlockStyle}"
                            Text="{Binding AdapterName}" />

                        <TextBlock
                            Grid.Row="1"
                            Style="{StaticResource BodyStrongTextBlockStyle}"
                            Text="DHCP" />
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="1"
                            Style="{StaticResource BodyTextBlockStyle}"
                            Text="{Binding DhcpText}" />

                        <TextBlock
                            Grid.Row="2"
                            Style="{StaticResource BodyStrongTextBlockStyle}"
                            Text="IPv4 address" />
                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="1"
                            Style="{StaticResource BodyTextBlockStyle}"
                            Text="{Binding IpAddress}" />

                        <TextBlock
                            Grid.Row="3"
                            Style="{StaticResource BodyStrongTextBlockStyle}"
                            Text="Subnet mask" />
                        <TextBlock
                            Grid.Row="3"
                            Grid.Column="1"
                            Style="{StaticResource BodyTextBlockStyle}"
                            Text="{Binding SubnetMask}" />

                        <TextBlock
                            Grid.Row="4"
                            Style="{StaticResource BodyStrongTextBlockStyle}"
                            Text="Gateway" />
                        <TextBlock
                            Grid.Row="4"
                            Grid.Column="1"
                            Style="{StaticResource BodyTextBlockStyle}"
                            Text="{Binding GatewayAddress}" />

                        <TextBlock
                            Grid.Row="5"
                            Style="{StaticResource BodyStrongTextBlockStyle}"
                            Text="DNS servers" />
                        <TextBlock
                            Grid.Row="5"
                            Grid.Column="1"
                            Style="{StaticResource BodyTextBlockStyle}"
                            Text="{Binding DnsServers}"
                            TextWrapping="Wrap" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource SectionCardBorderStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="Bootstrap guidance" />
                    <TextBlock
                        Margin="0,12,0,0"
                        Style="{StaticResource BodyTextBlockStyle}"
                        Text="Wi-Fi is not provisioned for this image. Foundry.Connect will keep validating ethernet reachability until the bootstrap can continue."
                        TextWrapping="Wrap" />
                    <TextBlock
                        Margin="0,12,0,0"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource BodyTextBlockStyle}"
                        Text="Closing this window returns a non-zero exit code so the bootstrap can stop safely."
                        TextWrapping="Wrap" />
                    <TextBlock
                        Margin="0,12,0,0"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource BodyTextBlockStyle}"
                        Text="{Binding NetworkActionStatusText}"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
